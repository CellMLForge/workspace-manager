{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2020"],
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./src",
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "useUnknownInCatchVariables": false
  },
  "include": ["src/main/**/*", "src/services/**/*", "src/domain/**/*"],
  "exclude": ["src/renderer/**/*", "node_modules", "dist"]
}