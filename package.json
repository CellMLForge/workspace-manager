{
  "name": "cellmlforge-workspace-manager",
  "version": "0.1.0",
  "description": "CellMLForge Workspace Manager - Desktop app for managing OMEX/COMBINE archives with git integration and GitHub push",
  "main": "dist/main/main.js",
  "homepage": "./",
  "author": "CellMLForge Team",
  "license": "MIT",
  "scripts": {
    "renderer-dev": "vite",
    "renderer-build": "vite build",
    "renderer-preview": "vite preview",
    "build-main": "tsc -p tsconfig.main.json",
    "typecheck-renderer": "vue-tsc --noEmit -p tsconfig.renderer.json",
    "build-ts": "npm run build-main && npm run typecheck-renderer",
    "electron-start": "wait-on http://localhost:5173 && electron .",
    "dev": "npm run build-main && concurrently \"npm run renderer-dev\" \"wait-on http://localhost:5173 && electron .\"",
    "prepare-icons": "node scripts/convert-icon.js",
    "dist": "npm run prepare-icons && npm run build-main && npm run renderer-build && electron-builder"
  },
  "devDependencies": {
    "@types/node": "^20.3.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "concurrently": "^8.1.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^2.0.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "typescript": "^5.1.3",
    "vite": "^8.0.5",
    "vue-tsc": "^2.2.10",
    "wait-on": "^7.0.1"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "@primeuix/themes": "^2.0.3",
    "archiver": "^5.3.1",
    "decompress": "^4.2.1",
    "electron-store": "^8.1.0",
    "isomorphic-git": "^1.29.0",
    "jszip": "^3.10.1",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.4",
    "vue": "^3.5.32",
    "xmlbuilder2": "^2.1.1"
  },
  "build": {
    "appId": "com.cellmlforge.workspacemanager",
    "productName": "CellMLForge Workspace Manager",
    "files": [
      "dist/**",
      "node_modules/**",
      "package.json"
    ],
    "directories": {
      "buildResources": "build"
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
